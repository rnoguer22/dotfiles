</main><script>
(function(){
  // ── Monthly / Annual toggle — swaps price text + CTA href + billed line ──
  var btnM = document.getElementById('bt-monthly');
  var btnA = document.getElementById('bt-annual');

  function setPeriod(period){
    btnM.classList.toggle('active', period === 'monthly');
    btnA.classList.toggle('active', period === 'annual');
    btnM.setAttribute('aria-selected', period === 'monthly');
    btnA.setAttribute('aria-selected', period === 'annual');

    var showM = period === 'monthly';
    document.querySelectorAll('[data-price-monthly], [data-billed-monthly], [data-credits-monthly]')
      .forEach(function(el){ el.hidden = !showM; });
    document.querySelectorAll('[data-price-annual], [data-billed-annual], [data-credits-annual]')
      .forEach(function(el){ el.hidden = showM; });

    document.querySelectorAll('a.plan-cta[data-href-monthly]').forEach(function(a){
      a.href = period === 'annual' ? a.dataset.hrefAnnual : a.dataset.hrefMonthly;
      // Modal opener reads `data-checkout` — keep it in sync with the
      // selected billing period so the right plan code is fed into init.
      var ck = period === 'annual'
        ? a.dataset.checkoutAnnual
        : a.dataset.checkoutMonthly;
      if (ck) a.setAttribute('data-checkout', ck);
    });
  }
  btnM.addEventListener('click', function(){ setPeriod('monthly'); });
  btnA.addEventListener('click', function(){ setPeriod('annual'); });

  // Read the default period from the toggle wrap and sync prices + CTAs to
  // it on first paint. The data attribute is the single source of truth so
  // marketing can flip the default without touching JS.
  var wrap = document.querySelector('.billing-toggle-wrap');
  var defaultPeriod = (wrap && wrap.dataset.defaultPeriod) || 'monthly';
  setPeriod(defaultPeriod);

  // ── Mobile carousel — center "Pro" on first paint, dots track active card ──
  var grid = document.getElementById('plans-grid');
  var dots = Array.prototype.slice.call(document.querySelectorAll('#plans-dots button'));
  if (!grid || !dots.length) return;

  function isMobile(){ return window.matchMedia('(max-width: 880px)').matches; }

  // Center the featured/Most-Popular card (Premium = index 1) on mobile load.
  function centerOnFeatured(){
    if (!isMobile()) return;
    var cards = grid.querySelectorAll('.plan-card');
    if (cards[1]) {
      cards[1].scrollIntoView({inline:'center', block:'nearest', behavior:'auto'});
    }
  }
  // Run on DOMContentLoaded (before images) AND on load (final layout) so
  // the user lands on Premium even if images push layout late.
  document.addEventListener('DOMContentLoaded', centerOnFeatured);
  window.addEventListener('load',   centerOnFeatured);
  window.addEventListener('resize', centerOnFeatured);

  // Update active dot based on which card is closest to viewport center
  function updateActiveDot(){
    if (!isMobile()) return;
    var cards = Array.prototype.slice.call(grid.querySelectorAll('.plan-card'));
    var center = grid.scrollLeft + grid.clientWidth / 2;
    var bestI = 0, bestD = Infinity;
    cards.forEach(function(c, i){
      var mid = c.offsetLeft + c.offsetWidth / 2;
      var d = Math.abs(mid - center);
      if (d < bestD) { bestD = d; bestI = i; }
    });
    dots.forEach(function(d, i){ d.classList.toggle('active', i === bestI); });
  }
  grid.addEventListener('scroll', function(){
    clearTimeout(grid._t); grid._t = setTimeout(updateActiveDot, 80);
  }, {passive: true});

  // Click a dot → smooth-scroll to that card
  dots.forEach(function(dot){
    dot.addEventListener('click', function(){
      var i = parseInt(dot.dataset.dot, 10);
      var cards = grid.querySelectorAll('.plan-card');
      if (cards[i]) cards[i].scrollIntoView({inline:'center', block:'nearest', behavior:'smooth'});
    });
  });
})();
</script><script>
  // Full-card-clickable plan cards. Click anywhere → navigate to the
  // card's primary CTA. Real anchors / buttons inside the card still
  // get their default handler (we ignore the parent click when the
  // event originated from a link or form control).
  (function(){
    document.querySelectorAll('.plan-card').forEach(function(card){
      var cta = card.querySelector('a.plan-cta, button.plan-cta');
      if (!cta) return;
      card.addEventListener('click', function(e){
        if (e.target.closest('a, button, input, select, textarea, label')) return;
        // Treat the active CTA href as the destination (annual/monthly
        // swap updates `href` already).
        if (cta.href) { window.location.href = cta.href; }
        else { cta.click(); }
      });
    });
  })();
