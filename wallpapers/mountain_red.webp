ttps://wallpapers.com/images/thumbnail/camouflaged-darter-3a50ed50f014d231.jpg", "url": "/wallpapers/camouflaged-darter-3a50ed50f014d231.html"}, {"alt": "Cicada nymph emerging from dry mud crack in desert, warm tones, harsh light, survival theme.", "thumb_url": "https://wallpapers.com/images/thumbnail/desert-emergence-5fb18fa5937d81c5.jpg", "url": "/wallpapers/desert-emergence-5fb18fa5937d81c5.html"}, {"alt": "Silhouette of cownose ray against sunset, dramatic.", "thumb_url": "https://wallpapers.com/images/thumbnail/sunset-silhouette-e2e036729094998e.jpg", "url": "/wallpapers/sunset-silhouette-e2e036729094998e.html"}, {"alt": "Cicada nymph on mossy branch, soft light, muted greens, peaceful woodland atmosphere.", "thumb_url": "https://wallpapers.com/images/thumbnail/mossy-branch-507f8be1eaae82f4.jpg", "url": "/wallpapers/mossy-branch-507f8be1eaae82f4.html"}, {"alt": "Close-up of a chiton\u0027s fleshy girdle with spines, soft morning light.", "thumb_url": "https://wallpapers.com/images/thumbnail/chiton-girdle-close-up-6b11c55108061e57.jpg", "url": "/wallpapers/chiton-girdle-close-up-6b11c55108061e57.html"}, {"alt": "Macro detail of a whelk shell with golden light", "thumb_url": "https://wallpapers.com/images/thumbnail/golden-spiral-whelk-2779171a9f7b1b41.jpg", "url": "/wallpapers/golden-spiral-whelk-2779171a9f7b1b41.html"}, {"alt": "Whelk shell on an old map with compass and candle", "thumb_url": "https://wallpapers.com/images/thumbnail/vintage-explorer-38899211fe35f994.jpg", "url": "/wallpapers/vintage-explorer-38899211fe35f994.html"}, {"alt": "A bowfin gliding through a dark swamp with bioluminescent accents.", "thumb_url": "https://wallpapers.com/images/thumbnail/swamp-phantom-b1554acca82370b8.jpg", "url": "/wallpapers/swamp-phantom-b1554acca82370b8.html"}, {"alt": "Atrina dancing on a moonlit beach", "thumb_url": "https://wallpapers.com/images/thumbnail/moonlit-dance-9cecd186d6c9db50.jpg", "url": "/wallpapers/moonlit-dance-9cecd186d6c9db50.html"}, {"alt": "Surreal portrait of Atrina floating in space among stars", "thumb_url": "https://wallpapers.com/images/thumbnail/cosmic-atrina-550e5ed644351dac.jpg", "url": "/wallpapers/cosmic-atrina-550e5ed644351dac.html"}, {"alt": "A bream fish resting on a stony riverbed in clear water.", "thumb_url": "https://wallpapers.com/images/thumbnail/resting-bream-on-riverbed-b5b095dad6f4abbf.jpg", "url": "/wallpapers/resting-bream-on-riverbed-b5b095dad6f4abbf.html"}, {"alt": "A fantasy digital painting of a bream with glowing patterns in deep sea.", "thumb_url": "https://wallpapers.com/images/thumbnail/bioluminescent-bream-dream-15e6d6fd19674aef.jpg", "url": "/wallpapers/bioluminescent-bream-dream-15e6d6fd19674aef.html"}, {"alt": "Intense macro shot of a skink\u0027s eye and scale texture in monochrome.", "thumb_url": "https://wallpapers.com/images/thumbnail/skink-eye-macro-8dab77a7957fe43b.jpg", "url": "/wallpapers/skink-eye-macro-8dab77a7957fe43b.html"}, {"alt": "A skink adapted to desert life on sandy terrain.", "thumb_url": "https://wallpapers.com/images/thumbnail/desert-skink-b92fa88fbff3efdb.jpg", "url": "/wallpapers/desert-skink-b92fa88fbff3efdb.html"}, {"alt": "Dynamic action of a tamarin swinging.", "thumb_url": "https://wallpapers.com/images/thumbnail/swinging-through-the-jungle-deb2d21232b93774.jpg", "url": "/wallpapers/swinging-through-the-jungle-deb2d21232b93774.html"}, {"alt": "A tamarin family cuddled together on a branch.", "thumb_url": "https://wallpapers.com/images/thumbnail/family-huddle-in-the-canopy-1af944fea4d99b1b.jpg", "url": "/wallpapers/family-huddle-in-the-canopy-1af944fea4d99b1b.html"}, {"alt": "A minimalist line art drawing of a tilapia on white background.", "thumb_url": "https://wallpapers.com/images/thumbnail/line-art-tilapia-634313ce0fb9c06f.jpg", "url": "/wallpapers/line-art-tilapia-634313ce0fb9c06f.html"}, {"alt": "A family of marmosets huddling together on a tree branch.", "thumb_url": "https://wallpapers.com/images/thumbnail/marmoset-family-on-branch-5ec7f6a526bc9bf8.jpg", "url": "/wallpapers/marmoset-family-on-branch-5ec7f6a526bc9bf8.html"}, {"alt": "A marmoset grooming itself on a bamboo stalk in macro detail.", "thumb_url": "https://wallpapers.com/images/thumbnail/grooming-marmoset-on-bamboo-935e0d6db789b5f3.jpg", "url": "/wallpapers/grooming-marmoset-on-bamboo-935e0d6db789b5f3.html"}, {"alt": "A clean vector illustration of a blue tang fish for a modern wallpaper.", "thumb_url": "https://wallpapers.com/images/thumbnail/minimalist-blue-tang-c75e778a27c11fd5.jpg", "url": "/wallpapers/minimalist-blue-tang-c75e778a27c11fd5.html"}, {"alt": "A blue tang navigating through a kelp forest with dappled light.", "thumb_url": "https://wallpapers.com/images/thumbnail/kelp-forest-blue-tang-aa2c3b4ab61710e4.jpg", "url": "/wallpapers/kelp-forest-blue-tang-aa2c3b4ab61710e4.html"}, {"alt": "Modern abstract geometric design featuring a weevil.", "thumb_url": "https://wallpapers.com/images/thumbnail/geometric-weevil-pattern-bedd64f4612083b6.jpg", "url": "/wallpapers/geometric-weevil-pattern-bedd64f4612083b6.html"}]' data-toppix-label="Pictures"></div>
